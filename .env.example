APP_NAME=Solar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# The public URL this front-end is served at. Drives canonical URLs, OG tags,
# sitemap and JSON-LD. e.g. https://sol.wickedsick.com
APP_URL=https://solar-system.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# This is a front-end only — it has no database of its own. All data comes from
# the Solar System DB REST API. Sessions and cache use the filesystem so the app
# runs on a £5 VPS with zero data services.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# --- Solar System DB backend (the read-only REST API this front-end consumes) ---
# Production: the deployed FastAPI host, e.g. https://sol.wickedsick.com/api/v1
# Local dev: run the backend repo's FastAPI server on :8003 (see README).
API_BASE_URL=https://sol.wickedsick.com/api/v1
# HTTP timeout in seconds for calls to the backend.
SOLAR_API_TIMEOUT=8
