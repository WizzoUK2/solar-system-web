APP_NAME=Solar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# The public URL this front-end is served at. Drives canonical URLs, OG tags,
# sitemap and JSON-LD. e.g. https://sol.wickedsick.com
APP_URL=https://solar-system.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# This is a front-end only — it has no database of its own. All data comes from
# the Solar System DB REST API. Sessions and cache use the filesystem so the app
# runs on a £5 VPS with zero data services.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Defaults are zero-dependency (no services needed) and CI-safe.
# On Forge with Redis, switch the three lines below to redis and run a queue
# worker — that enables true background stale-while-revalidate. See DEPLOYMENT.md.
QUEUE_CONNECTION=sync
CACHE_STORE=file
# Production (Forge + Redis):
#   QUEUE_CONNECTION=redis
#   CACHE_STORE=redis
#   SESSION_DRIVER=redis
#   REDIS_HOST=127.0.0.1
#   REDIS_PASSWORD=null
#   REDIS_PORT=6379

# --- Solar System DB backend (the read-only REST API this front-end consumes) ---
# Production: the FastAPI backend on its own subdomain (the front-end is
# sol.wickedsick.com; the API is separate). Set this to the deployed host.
# Local dev: run the backend repo's FastAPI server on :8003 (see README).
API_BASE_URL=https://api.sol.wickedsick.com/api/v1
# HTTP timeout in seconds for calls to the backend.
SOLAR_API_TIMEOUT=8

# --- Open Graph share cards ---
# Disk used to cache rendered per-object OG cards. `local` for dev/CI; `s3` in
# production (Ceph RGW — see below). Requires the imagick PHP extension.
OG_DISK=local
# OG_VERSION=v1
# OG_TTL=2592000

# --- S3 object storage (Ceph RGW, s3.wickedsick.com) ---
# Used by the `s3` disk when OG_DISK=s3. Bucket + keys are provisioned per the
# Engineering Wiki runbook; see docs/CEPH-S3.md.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=https://s3.wickedsick.com
# Virtual-hosted-style addressing (bucket.s3.wickedsick.com); keep false.
AWS_USE_PATH_STYLE_ENDPOINT=false
